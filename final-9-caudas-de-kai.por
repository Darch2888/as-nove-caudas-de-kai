  funcao feudo(){
    escreva(". ...... .........*#%***.... :----...:::::.----------::....:::::-.:--@%@@@@%%@---:::::::::::::::::::::::::::::::::::::::::+++:::::::-:::::::::::+%%%%%+::::::::.\n")
    u.aguarde(10)
    escreva(".::::++=+.===::.::=*##*==:=::--:::::.::::::------..-.:.:--:::..---.--%%%@@@@@@---:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::+*%%%*+::::::::.\n")
    u.aguarde(10)
    escreva(".%%%.++++ ===%%:%%.....==-=--..:--.::::: -----: ----.----------------@%@%@@@%----:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::+******::::::::.\n")
    u.aguarde(10)
    escreva(".%%%.++++.===%%:%%.=-====-=----------::::..----.-:.------------..--.:.-@@@@------::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::--:...-----:::::.\n")
    u.aguarde(10)
    escreva(" %#%.++++.===%%:%%.=-====:=.----------.::::.:::--------:::.-----:---.:.--------::::::::::::::::::::::::::::::::::::::::::::::::::==--::::::::-----------=::::::.\n")
    u.aguarde(10)
    escreva(".....=+++.=====-==-=-====-=--:-----::.:::::::--:.--..--:-::.-------.---...-::::::::::::::::---:::::::::::::-----::::::::::::::--------=:::::::--------=::::::::.\n")
    u.aguarde(10)
    escreva(".+==+==++.=====-==-=-====-=---.:-----.::::.------:---.:--: -::.:-::.::--:..:::::::::::::::------::::::::::=----::::::::::::::-=--------::::::=---------::::::::.\n")
    u.aguarde(10)

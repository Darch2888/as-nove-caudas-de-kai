programa {
    inclua biblioteca Util --> u
      inclua biblioteca Tipos --> tp
    
    // Variável global para pausas de leitura
    cadeia enter

    funcao inicio() {
    inteiro opcaoAto1
    inteiro opcaoAto2
    inteiro opcaoAto3
    inteiro opcaoAto4_1  // Agora são duas variáveis separadas
    inteiro opcaoAto4_2
    inteiro opcaoAto5
    inteiro pontuacao

    // --- CORREÇÃO: Descomentando a introdução e primeiros atos ---
    u.aguarde(900)
    carregando1()
    u.aguarde(500)
    limpa()

    carregando2()
    u.aguarde(600)
    limpa()

    carregando3()
    u.aguarde(500)
    limpa()

    carregando1()
    u.aguarde(600)
    limpa()

    carregando2()
    u.aguarde(500)
    limpa()

    carregando3()
    u.aguarde(600)
    limpa()

    capa()
    u.aguarde(3000)
    continuar()
    limpa()

    contexto()
    opcaoAto1 = ato1()
    opcaoAto2 = ato2()
    opcaoAto3 = ato3()

    // Ato 4: Executa AMBOS os caminhos, a ordem depende da escolha do ato 3
    se (opcaoAto3 == 1) {
      opcaoAto4_1 = ato4_1()  // Floresta primeiro
      opcaoAto4_2 = ato4_2()  // Depois Montanha
    } senao {
      opcaoAto4_2 = ato4_2()  // Montanha primeiro
      opcaoAto4_1 = ato4_1()  // Depois Floresta
    }

    ato4_3()
    opcaoAto5 = ato5()

    // Calcula pontuação acumulada: 
    // Pontos são dados para escolhas de "Empatia/Cautela/Sabedoria"
    // Ato 1: Opção 1 (Silêncio) = +1
    // Ato 2: Opção 2 (Observar) = +1
    // Ato 3: Opção 1 (Floresta) = +1
    // Ato 4 Floresta: Opção 2 (Sabedoria) = +1
    // Ato 4 Montanha: Opção 2 (Fendas) = +1
    // Ato 5: Opção 1 (Serenidade) = +1
    
    pontuacao = 0
    se (opcaoAto1 == 1) { pontuacao = pontuacao + 1 }
    se (opcaoAto2 == 2) { pontuacao = pontuacao + 1 }
    se (opcaoAto3 == 1) { pontuacao = pontuacao + 1 }
    se (opcaoAto4_1 == 2) { pontuacao = pontuacao + 1 }  // Floresta
    se (opcaoAto4_2 == 2) { pontuacao = pontuacao + 1 }  // Montanha
    se (opcaoAto5 == 1) { pontuacao = pontuacao + 1 }

    epilogo(opcaoAto5, pontuacao)
    }

  // Ambientação, contexto do jogo
    funcao contexto() {
     escreva(" <===========================================>\n") 
     escreva("                O FEUDO DE KAI\n")
     escreva(" <===========================================>\n")
     feudo()
     u.aguarde(600)
     escreva("\nCercado pelos gigantescos Alpes Japoneses e vigiado pela silhueta eterna do Monte Fuji.\n")
     u.aguarde(800)
     escreva("\nSeu nome é Akira, 20 anos.\n")
     u.aguarde(800)
     escreva("\nCurioso demais para não passar dos limites do feudo.\n")
     u.aguarde(800)
     continuar()
     limpa()

     floresta_adentro1()
     u.aguarde(700)
     escreva("\nDizem que a floresta abriga espíritos de raposas.\n")
     u.aguarde(800)
     escreva("\nAstútas, protetoras da floresta...\n")
     u.aguarde(800)
     escreva("\nE provadoras dos mortais...\n")
     u.aguarde(800)
     escreva("\n\nOnde o vento se ergue, a noite chama\n")
     u.aguarde(800)
     continuar()
     limpa()
    }

    funcao inteiro ato1() 
  {
    inteiro opcao    
    escreva(" <===========================================>\n") 
    escreva("   ATO I - O Festival e a Garota Misteriosa\n")
    escreva(" <===========================================>\n")
    u.aguarde(800)
    escreva("\nLanternas dançam no ar.\n")
    u.aguarde(800) 
    escreva("\nRisos e música ecoam pelas ruas.\n") 
    u.aguarde(800)
    escreva("\nEntre a multidão,\n")
    u.aguarde(800)
    escreva("\numa jovem de cabelos prateados.\n") 
    u.aguarde(800)
    escreva("\nEla caminha em direção à floresta.\n")
    u.aguarde(800)
    escreva("\nObserva as árvores com preocupação.\n") 
    u.aguarde(800)
    escreva("\nAlgo está errado.\n") 
    u.aguarde(800)
    escreva("\nE você sente isso.\n")
    u.aguarde(800)
    continuar()
    limpa()  
      
    escreva("\nA partir daí, o que você faz?\n\n")
    e1()
       escreva("\n\n1) Seguir em silêncio\n")
       escreva("2) Chamar por ela\n")
    u.aguarde(300)
    opcao = obter_opcao(1, 2)
    limpa()
    
    se (opcao == 1) { 
      mulher_caverna()       
      escreva("\nVocê usa as sombras das árvores, ouve um sussurro da jovem antes dela entrar na caverna.\n")
      u.aguarde(300)
      escreva("\n<============================================> ")
      u.aguarde(300)
      escreva("\n<======== Pressione ENTER para ouvir ========> ")
      u.aguarde(300)
      escreva("\n<============================================> ")
      leia(enter)
      limpa()

      u.aguarde(500)
      escreva("\n\n- A voz dela fraqueja. Como se sustentar aquilo exigisse mais do que deveria. -\n")
      u.aguarde(500)
      escreva("\n\n'Elas não estão mais alinhadas'\n")
      u.aguarde(800)
      escreva("\n'Manter todas juntas assim…'\n")
      u.aguarde(800)
      escreva("\n'Já está cobrando um preço alto.'\n")
      u.aguarde(500)

      escreva("\n'As raízes estão reagindo...'\n")
      u.aguarde(800)
      escreva("\n'O feudo está reagindo...'\n")
      u.aguarde(500)
      escreva("\nA moça misteriosa entra na caverna.")
      u.aguarde(500)
      escreva("\nVocê entra atrás dela.\n")

    } senao {
      mulher_caverna()
      escreva("\n\n\nVocê tenta alertá-la sobre o perigo da floresta à noite,\n")
      u.aguarde(800)
      escreva("\nMas ela se assusta e entra na caverna mais rápido.\n")
      u.aguarde(800)
      escreva("Você entra na caverna atrás da moça misteriosa.\n")      
    }
    u.aguarde(800)
    escreva("\n<============================================> ")
    u.aguarde(300)
    escreva("\n<== Pressione ENTER para entrar na caverna ==> ")
    u.aguarde(300)
    escreva("\n<============================================> ")
    leia(enter)
    limpa()

    retorne opcao
    }

    funcao inteiro ato2() 
  {
    inteiro opcao
    escreva(" <===========================================>\n") 
    escreva("  ATO II - Caverna das Sombras, Kage-no-Iwaya\n")
    escreva(" <===========================================>\n")  
    u.aguarde(300)
    escreva("\nO ar vibra, sombras se movem sozinhas.\n") 
    u.aguarde(800)
    escreva("\nVocê cruza o limiar...\n")
    u.aguarde(800)
    escreva("\nHá um altar de rochas no centro da caverna.\n")
    u.aguarde(800)
    escreva("\nA jovem fala, mas não há ninguém além de vocês dois.\n")
    u.aguarde(800)
    escreva("\nAlgo responde, mesmo no silêncio.\n")
    u.aguarde(1000)
    continuar()
    limpa()

    escreva("\nAgora que alcançou a garota, o que fazer?\n\n")
    e2()
      escreva("\n\n1) Confrontar a garota")
      escreva("\n2) Observar e esperar\n")
    opcao = obter_opcao(1, 2)
    limpa()

    se (opcao == 1) {
      escreva("\nVocê corre para o altar: \n'O que você está fazendo aqui?!'\n\n")
      escreva("A menina se assusta e dá um passo para trás.\n")
    } senao {
      escreva("\nVocê tenta entender o que ela diz,\n")
      escreva("Mas sua voz é trêmula e ela sussurra o que parecem ser palavras antigas")
    }

    u.aguarde(300)
    passarTexto()

    escreva("\n\nDe repente, o chão estremece sob seus pés,\n")
    u.aguarde(800)
    escreva("\nUm brilho súbito e ofuscante queima o ar, forçando-o a cobrir os olhos.\n")
    u.aguarde(800)
    escreva("\nA luz finalmente cede e você vê que o vazio da gruta foi preenchido:")
    u.aguarde(800)
    escreva("\n\nOnde antes estava a jovem, agora existem nove versões dela, cercando o altar.")
    passarTexto()

    escreva("\n\nTodas brilham...")
    u.aguarde(900)
    escreva("\n\nE tão rápido quanto apareceram...")
    u.aguarde(900)
    escreva("\n\nSe foram...\n")
    u.aguarde(600)
    continuar()
    limpa()

    retorne opcao
    }

 funcao inteiro ato3() 
  {
    inteiro opcao
    escreva(" <===========================================>\n") 
    escreva("  ===== ATO III - O Desequilibrio de Kai ====\n")
    escreva(" <===========================================>\n")  
    u.aguarde(300)
    escreva("\nVocê olha, incrédulo, para o altar: 'Como isso é possível?! Aliás, o que foi isso?'\n")
    u.aguarde(300)
    escreva("\n 'Você nunca ouviu falar da raposa de nove caudas que guarda a floresta de Kai?'- diz uma voz feminina, surgindo do vazio às suas costas.\n")
    u.aguarde(300)
    escreva("\nAo se virar você vê dois clones da moça olhando-o fixamente.")
    passarTexto()

    u.aguarde(300)
    escreva("\n\n'Não tema, jovem Akira. Somos as caudas da Sabedoria' - apontou para si - ")
    u.aguarde(200)
    escreva("'\ne Serenidade,' - a outra faz uma leve reverência - 'você está aqui porque precisamos da sua ajuda'")
    u.aguarde(300)
    escreva("\n\n'Não temos muito tempo para explicar, mas podemos podemos lhe dizer o seguinte:' - disse a Serenidade")
    u.aguarde(300)
    escreva("\n\n'As caudas da Ganância e do Caos se juntaram para tentar assumir o controle e acabar com o equilíbrio de Kai'")
    u.aguarde(300)
    passarTexto()

    escreva("\n\n'O que fez com que o equilíbrio das nove caudas fosse desfeito e acabamos nos separando.") 
    u.aguarde(200)
    escreva("\nVocê precisa nos ajudar a achar reunir as outras caudas antes do Caos e da Ganância'")
    u.aguarde(300)
    escreva("\n\n'Jovem de Kai, nós aguentamos até sua vinda e agora contamos com sua ajuda para restaurar a alma da Nove Caudas.'\n")
    u.aguarde(900)
    continuar()
    limpa()

    u.aguarde(300)
    escreva("\nO ar na caverna parece mais pesado agora.\n")
    u.aguarde(300)
    escreva("\n 'Mas por onde começamos?' — você pergunta, fechando os punhos com determinação.\n")
    u.aguarde(300)
    escreva("\nSabedoria dá um passo à frente, seus olhos brilhando como brasas antigas:\n")
    u.aguarde(300)
    escreva("\n 'O desequilíbrio já começou a sangrar para fora destas paredes. Sinto dois caminhos urgentes, Akira.'\n")
    u.aguarde(800)
    continuar()
    limpa()

    u.aguarde(300)
    escreva("\nSerenidade aponta para a saída da caverna, onde o céu de Kai está estranhamente rubro:\n")
    u.aguarde(300)
    escreva("\n 'A Devoção e a Astúcia foram vistas na Floresta Sussurrante; os animais lá perderam o espírito e atacam quem cruza seu caminho.'\n")
    u.aguarde(300)
    escreva("\n 'Por outro lado, a Ira e a Melancolia se refugiaram na Montanha do Vento Partido. O medo delas está fazendo as colheitas murcharem e o povo sofrer.'\n")
    u.aguarde(300)
    escreva("\n 'Você é o guia físico neste mundo, Akira. Para onde sua intuição o leva primeiro?'\n")
    u.aguarde(800)

    escreva("\nDiante delas, o que você faz?\n")
    e3()    
     escreva("\n\n1) Seguir para a Floresta Sussurrante")
     escreva("\n2) Seguir para a Montanha do Vento Partido\n\n")
     opcao = obter_opcao(1, 2)
     limpa()

    se (opcao == 1) {
     escreva("\n 'Devemos ir para a Floresta primeiro, nossa prioridade é a natureza.'\n")
    } senao {
    escreva("\n 'Devemos ir para a Montanha primeiro, nossa prioridade é o povo de Kai.' \n")
    }

    u.aguarde(600)
    escreva("\n\n A partir daí, começa a sua aventura em busca das nove caudas de Kai!!! \n")
    u.aguarde(300)
    escreva("\n <~~ Boa sorte, jovem Akira!!! ~~>\n\n")
    u.aguarde(300)
    continuar()
    limpa()
    retorne opcao
  }


 funcao inteiro ato4_1() 
  {
    inteiro opcao
    escreva(" <===========================================>\n") 
    escreva("  ====== ATO IV - A Busca pelas Caudas ======\n")
    escreva(" <===========================================>\n")  
    u.aguarde(300)

  // Floresta Sussurrante (Esconderijo - Devoção (Shin) e Astúcia (Kyo))
    escreva("\nVocês seguem para a Floresta Sussurrante em busca das caudas da Devoção e Astúcia.")
    u.aguarde(300)
    escreva("\n\nNessa floresta, árvores mudam de lugar e as vozes enganam os sentidos.")
    u.aguarde(300)
    escreva("\n\nVocê começa a ficar confuso com tantas vozes ecoando em sua cabeça e, para piorar, as ilusões da floresta te impedem de seguir o caminho que havia traçado primeiramente.")
    u.aguarde(300)
    escreva("\n\nNão existe a possibilidade de sentar e esperar até que tudo passe, então chegou a hora de escolher:\n")
    u.aguarde(300)
    continuar()
    limpa()

    escreva("\nO que você prefere?\n\n")
    e4()
      escreva("\n\n1) Confiar nos seus ouvidos")
      escreva("\n2) Seguir a dica da Sabedoria\n\n")
    opcao = obter_opcao(1, 2)
    limpa()

    se (opcao == 1) {
     limpa()
     escreva("\nAs vozes prometem o caminho certo, mas as árvores se fecham ao seu redor.")
     u.aguarde(500)
     escreva("\n\nVocê cai em uma armadilha de raízes antigas! A Astúcia ri ao longe.")
     u.aguarde(500)
     escreva("\n\nFoi gasto muito tempo para se libertar e perde o rastro das caudas, forçando-o a recuar.\n") //e optar pelo caminho da Montanha???
     u.aguarde(500)
     escreva("\n\n Depois de andar por alguns metros, você dá de cara com as caudas da Devoção e Astúcia.")
     u.aguarde(500)
    } senao {
     limpa()
     escreva("\n\nA Sabedoria o orienta a ignorar os sons e focar no brilho das flores.")
     u.aguarde(300)
     escreva("\n\nAs ilusões se dissipam e você encontra um rastro de pétalas de cerejeira.")
     u.aguarde(500)
     escreva("\n\nO rastro leva você diretamente ao esconderijo da Devoção e Astúcia!\n")
    }
    escreva("\n\n Após conversar com a Devoção, vocês dois conseguem argumentar com a Astúcia e fazer com que todas sigam viagem junto com você.")
    u.aguarde(500)
    continuar()
    limpa()

    retorne opcao
  }

 funcao inteiro ato4_2() 
  {
    inteiro opcao
    escreva(" <===========================================>\n") 
    escreva("  ====== ATO IV - A Busca pelas Caudas ======\n")
    escreva(" <===========================================>\n")  
    u.aguarde(300)

  // Montanha do Vento Partido (Esconderijo - Ira (Ikari) e Melancolia (Urei))
   escreva("\nO vento ruge como um animal ferido neste desfiladeiro.")
   u.aguarde(600)
   escreva("\n\nNuvens de poeira e neve cobrem a visão, escondendo o abismo que se abre aos seus pés.")
   u.aguarde(600)
   escreva("\n\nA Ira e a Melancolia parecem sussurrar entre as rajadas, desafiando sua determinação.")
   u.aguarde(9000)           

    escreva("\nComo você pretende avançar por este terreno implacável?\n\n")
     e5()
     escreva("\n\n1) Escalar pelo caminho íngreme e exposto")
     escreva("\n2) Contornar pelas fendas estreitas")
     opcao = obter_opcao(1, 2)
     limpa()

    se (opcao == 1) {
     escreva("\n\nA subida é brutal e o vento corta como navalhas. O frio extremo deixou marcas em suas mãos.")
     u.aguarde(600)
     escreva("\n\nA Sabedoria olha para suas feridas com preocupação.\n")
     u.aguarde(600)
     escreva("\n\nNo topo, porém, sua visão é privilegiada: você avista o brilho da Ira e da Melancolia.")
     u.aguarde(600)
     escreva("\n\nVocê sabe exatamente para onde ir agora.\n")
    } senao {
     escreva("\n\nAs fendas protegem você do vento, mas o caminho é sombrio e úmido.")
     u.aguarde(600)
     escreva("\n\nDezenas de espíritos menores perdidos bloqueiam sua passagem com lamentos.")
     u.aguarde(600)
     escreva("\n\nVocê precisa acalmá-los antes de seguir viagem, o que atrasa sua busca.")
     u.aguarde(600)
     escreva("\n\nQuando você finalmente sai, a noite já caiu.\n")
     u.aguarde(600)
     escreva("\n\n'O desequilíbrio no feudo aumentou' - diz a Sabedoria - 'Algumas consequências são irreversíveis...'\n")
    }

    u.aguarde(600)
    continuar()
    limpa()

    u.aguarde(600)
    escreva("\n\nVocê convence as caudas a colaborar e continua sua jornada para salvar o feudo de Kai \n")

    retorne opcao
  }

  // Cachoeira Invertida (Esconderijo - Esperança (Kizashi))
  funcao ato4_3() 
  {
    inteiro opcao
    escreva(" <===========================================>\n") 
    escreva("  ====== ATO IV - A Busca pelas Caudas ======\n")
    escreva(" <===========================================>\n")  
    u.aguarde(300)

    escreva("\n\nDepois de reunir a força da Ira, o peso da Melancolia, a fé da Devoção e as táticas da Astúcia,")
    u.aguarde(200)
    escreva("\n\nVocês chegam a um vale onde o som do mundo parece mudo, substituído por um zumbido de luz.")
    u.aguarde(200)
    escreva("\n\nDiante de seus olhos, a Cachoeira Invertida ignora as leis dos mortais.")
    u.aguarde(200)
    passarTexto()

    escreva("\n\nA água desafia a gravidade, subindo em direção ao céu de Kai.\n")
    u.aguarde(200)
    escreva("\n'Aqui se esconde a Esperança' - diz a Serenidade com um meio sorriso.")
    u.aguarde(200)
    escreva("\n\n'Ela é a luz que resta quando tudo parece perdido. Para alcançá-la, sua visão deve ser clara.'")
    passarTexto()
    u.aguarde(200)
    escreva("\n\nO brilho da água invertida é ofuscante, criando mil reflexos que escondem o espírito da raposa.\n")
    u.aguarde(200)
    escreva("\n'Beber da água te daria Visão Espiritual, o que facilitaria ver através do brilho' - diz Astúcia")
    u.aguarde(200)
    escreva("\n\n'Mas meditar te permitiria sentir a presença da Esperança pelo espírito.' - aconselha Serenidade")
    u.aguarde(900)
    continuar()
    limpa()

    escreva("\nComo você pretende encontrar a Esperança no meio desta luz?\n\n")
     e6()
     escreva("\n\n1) Beber da água")
     escreva("\n2) Meditar sob a queda d'água com a Serenidade\n\n")
     opcao = obter_opcao(1, 2)
     limpa()

      se (opcao == 1) {
       escreva("\nApós beber da água, sua visão brilha! O caminho oculto se revela entre as gotas que sobem.")
       u.aguarde(800)
       escreva("\n\nMas o passado de Tamamo inunda sua mente, deixando você tonto e confuso.")
       u.aguarde(800)
       escreva("\n\nCambaleia, mas consegue ver a silhueta da Esperança à frente.\n")
       u.aguarde(900)
       continuar()
       limpa()
      } senao {
       limpa()
       escreva("\nVocê se senta e deixa a água invertida lavar suas dúvidas. O tempo parece parar.")
       u.aguarde(700)
       escreva("\n\nSua mente se torna um espelho limpo. A paz que emana de você atrai o espírito.")
       u.aguarde(800)
       escreva("\n\nSentindo sua calma, a Esperança surge voluntariamente do meio da névoa.\n")
       u.aguarde(900)
       continuar()
       limpa()
      }

    escreva("\nAo ficar frente a frente com a Esperança, você se prepara para falar, mas ela o interrompe:")
    u.aguarde(200)
    escreva("\n\n 'Não há necessidade de explicações, Akira. Vi seu brilho desde que cruzou o limiar da Caverna das Sombras.'")
    u.aguarde(200)
    escreva("\n\n 'O Caos e a Ganância pensam que o mundo é feito de sombras, mas elas esqueceram que sombras só existem onde há luz.'")
    u.aguarde(800)
    passarTexto()

    escreva("\n\n 'Você provou que é digno de carregar a responsabilidade de um guardião. Mas me diga, jovem de Kai...'")
    u.aguarde(800)
    escreva("\n\n 'Quando o céu escurecer e o Monte Fuji tremer sob a vontade daquelas que nos traíram,'")
    u.aguarde(800)
    escreva("\n\n 'você terá coragem de ser a lanterna de seu povo, mesmo se for a última que restar?'")
    u.aguarde(800)
    escreva("\n\n 'Eu serei a luz de que Kai precisa.'\n")
    u.aguarde(800)
    escreva("\n\nAgora, todas as caudas resgatadas brilham em uníssono. É hora do confronto final.\n")
    u.aguarde(1000)
    continuar()
    limpa()

  }


 funcao inteiro ato5() 
  {
   inteiro opcao

   escreva(" <===========================================>\n") 
   escreva(" ========== ATO V - Confronto Final ==========\n")
   escreva(" <===========================================>\n")  
   u.aguarde(300)

   escreva("\nVocê e as sete caudas finalmente se dirigem ao núcleo do desequilíbrio")
   u.aguarde(200)
   escreva("\nOnde o céu é escuridão e o Monte Fuji parece sangrar lava negra...\n")
   u.aguarde(200)
   escreva("\nDiante de vocês, uma fenda colossal rasga a terra, revelando o Abismo do Espelho Rubro.")
   passarTexto()

   escreva("\n\nLá embaixo, o chão de obsidiana é como um vidro escuro que reflete não o rosto de quem olha, mas sim o que há de pior em cada alma.\n")
   u.aguarde(200)
   escreva("\nNo centro do abismo, as duas vilãs se fundem em uma forma grotesca e instável...\n")
   u.aguarde(200)
   escreva("\nO Caos ri, um som que estraçalha a lógica, enquanto a Ganância devora a própria luz ao redor.")
   passarTexto()
   u.aguarde(200)
   
   escreva("\n\n 'Akira...' - a voz da Ganância ecoa - 'Tanto esforço para juntar os pedaços de uma carcaça velha?'\n")
   u.aguarde(200)
   escreva("\n 'Junte-se a nós' - provoca o Caos, distorcendo o espaço - 'Por que salvar um feudo que apodrece, se você pode reinar em um novo mundo?...'")
   u.aguarde(1000)
   continuar()
   limpa()
  

   escreva("\n\nAs caudas ao seu lado brilham intensamente, Sabedoria e a Serenidade sussurram duas estratégias opostas: \n")
   u.aguarde(800)
   escreva("\n 'Você pode usar sua vitalidade humana para purificar a Ganância, ou...' - começa a Serenidade")
   u.aguarde(800)
   escreva("\n 'Você pode usar a Astúcia e a Ira para sobrecarregá-las.' - completou a Sabedoria")
   u.aguarde(3000)
   
   escreva("\nComo você lutará contra as caudas malignas?\n\n")
   e7()
   escreva("\n\n1) Caminho da Serenidade")
   escreva("\n2) Caminho da Sabedoria\n\n") 
   opcao = obter_opcao(1, 2)
   limpa()

    se (opcao == 1) {
     escreva("Você usa todas as forças de seu espírito e consegue redimir a Ganância, fazendo com que ambas voltem às suas formas originais,\n")
     u.aguarde(500)
     escreva("Porém fica extremamete fraco e debilitado, dependendo agora exclusivamente da competência das caudas reunidas\n")
     u.aguarde(900)
     continuar()
     limpa()
    } senao {
     escreva("Com a ajuda da Ira e Astúcia, você cria uma sobrecarga de energia que força a separação das entidades com uma explosão\n")
     u.aguarde(500)
     escreva("Graças à sua escolha de estratégia, você mantem sua energia vital e ainda pode dar suporte às caudas") 
     u.aguarde(500)
     escreva("\nParece que a explosão de energia afetou significativamente o Feudo de Kai...\n")
     u.aguarde(900)
     continuar()
     limpa()
    }
    retorne opcao
  }


funcao epilogo(inteiro escolhaAnterior, inteiro pontuacao) 
{
    escreva(" <===========================================>\n") 
    escreva("  ===== ATO VI - O Destino da Guardiã =======\n")
    escreva(" <===========================================>\n")  
    u.aguarde(1000)

    se (escolhaAnterior == 1) {
        escreva("\nO silêncio cai sobre o Abismo do Espelho Rubro.")
        u.aguarde(300)
        escreva("\n\nVocê está de joelhos, sua vitalidade quase extinta após purificar a Ganância.")
        u.aguarde(300)
        escreva("\n\nAs nove caudas flutuam ao seu redor, brilhando com uma pureza que dói aos olhos.")
        u.aguarde(900)
        continuar()
        limpa()
    } senao {
        escreva("\nAs chamas da explosão de energia ainda lambem o horizonte de Kai.")
        u.aguarde(300)
        escreva("\n\nEmbora exausto, você permanece de pé. As nove caudas estão dispersas,")
        u.aguarde(300)
        escreva("\n\nEncolhidas pela força bruta da sobrecarga, mas finalmente livres da corrupção.")
        u.aguarde(808)
        continuar()
        limpa()
    }

    u.aguarde(1000)
    escreva("\n\nA essência de Tamamo-no-Mae pulsa entre as nove caudas como um coração que não sabe se deve bater ou se despedaçar.")
    u.aguarde(800)
    escreva("\n\nO equilíbrio de Kai foi restaurado — mas a Guardiã permanece fragmentada, suspensa entre a reunificação e algo que nenhuma das caudas ousa nomear.")
    u.aguarde(800)
    escreva("\n\nE agora, todos aqueles olhos — da fúria à ternura — estão fixos em você.")
    u.aguarde(800)
    continuar()
    limpa()

    se (escolhaAnterior == 1 e pontuacao >= 4) {

      escreva("\n<===========================================>\n")
      escreva("\n ========== O SACRIFÍCIO DE AKIRA ==========\n")
      escreva("\n<===========================================>\n")
      u.aguarde(600)

      escreva("\nVocê olha para suas mãos. Não sente mais nada.")
      u.aguarde(500)
      escreva("\n\nNão é dor — é ausência. Como se o próprio conceito de 'toque' tivesse se dissolvido junto com sua vitalidade.")
      u.aguarde(900)
      passarTexto()
      

      escreva("\n\nAs nove caudas observam em silêncio. A Sabedoria é a primeira a entender.")
      u.aguarde(400)
      escreva("\n\n'Você se esvaziou completamente, Akira. Não há mais nada a sustentar seu corpo mortal.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\n'Akira...' — a Serenidade avança, a voz quebrando — 'Podemos tentar sustentá-lo com nossa energia, mas—'")
      u.aguarde(400)
      escreva("\n\n'Não.'")
      u.aguarde(400)
      escreva("\n\nSua voz é calma. Não há medo nela. Só clareza.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\n'Se me fundirem, não será como Tamamo. Ela era guardiã da luz, do equilíbrio visível.'")
      u.aguarde(400)
      escreva("\n'Mas Kai precisa de mais que isso. Precisa de alguém que cuide do que a luz não alcança.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\n'As sombras. Os medos noturnos. Os espíritos perdidos que vagam sem rumo.'")
      u.aguarde(400)
      escreva("\n\n'Eu posso ser isso.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nVocê se levanta — não com força, mas com algo maior que força.")
      u.aguarde(400)
      escreva("\n\nE abre os braços para as nove caudas.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\n'Fundam-se a mim. Não para me salvar — mas para que eu possa salvar o que resta nas trevas.'")
      u.aguarde(400)
      escreva("\n\nPela primeira vez em milênios, as nove caudas choram.")
      u.aguarde(400)
      escreva("\n\nNenhum mortal jamais pediu para se tornar sombra por vontade própria.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nA fusão começa.")
      u.aguarde(400)
      escreva("\n\nAs nove caudas se enrolam ao seu redor como serpentes de luz prateada, penetrando sua pele, seus ossos, sua alma.")
      u.aguarde(400)
      escreva("\n\nDor não existe mais. Existe apenas expansão.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nSeu corpo se dissolve em névoa negra e prata.")
      u.aguarde(400)
      escreva("\n\nSuas mãos viram garras de sombra. Seus olhos viram brasas que brilham no escuro.")
      u.aguarde(400)
      escreva("\n\nMas seu coração — esse permanece humano. Esse permanece Akira.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nVocê se torna o Guardião das Sombras de Kai.")
      u.aguarde(400)
      escreva("\n\nNão uma raposa. Não um espírito. Algo novo — um mortal que carrega nove caudas dentro de si") 
      u.aguarde(400)
      escreva("\n\nCuja forma é feita de escuridão viva e cujo propósito é proteger o que habita na noite.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nO céu de Kai se limpa. O Monte Fuji volta a brilhar sob a lua.")
      u.aguarde(400)
      escreva("\n\nMas agora, quando a noite cai, as sombras se movem com intenção.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nAs crianças não temem mais o escuro. Porque sabem, de algum lugar profundo, que algo observa por elas.")
      u.aguarde(400)
      escreva("\n\nOs espíritos malignos não ousam cruzar as fronteiras de Kai. Porque nas sombras entre as árvores, há olhos esperando.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nTamamo não retorna. A Guardiã de Prata se foi para sempre.")
      u.aguarde(400)
      escreva("\n\nEm seu lugar, algo mais silencioso caminha entre a névoa.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\n\nGerações depois, os monges de Kai escreveriam nos pergaminhos mais antigos:")
      u.aguarde(400)
      escreva("\n\n'Não clamemos pela luz quando a escuridão nos protege.'")
      u.aguarde(400)
      escreva("\n\n'O Guardião das Sombras não é monstro. É a prova de que um mortal amou este feudo mais do que amou a si mesmo.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nE nas noites mais silenciosas, se alguém parar e realmente olhar para a sombra ao seu lado...")
      u.aguarde(400)
      escreva("\nPode ver, por um instante, a silhueta de um jovem de vinte anos, com nove caudas de escuridão ondulando atrás de si.")
      u.aguarde(800)
      continuar()
      limpa()
      
      escreva("\n\nEle não fala. Não sorri. Mas está ali.")
      u.aguarde(400)
      escreva("\n\nSempre ali.\n\n")
      u.aguarde(2000)
      guardiao()
      escreva("\n\n>> O Guardião das Sombras <<\n")
      continuar()
     limpa()

    } senao se (escolhaAnterior == 1) {

      escreva("\n<===========================================>\n")
      escreva("\n ==========  A GUARDIÃ E O SÁBIO  ==========\n") 
      escreva("\n<===========================================>\n")
      u.aguarde(600)

      escreva("\n\nSua vitalidade foi drenada, mas não até o fim. Ainda sobra algo — um fio tênue de vida que se recusa a quebrar.")
      u.aguarde(500)
      escreva("\n\nE é esse fio que muda tudo.")
      u.aguarde(500)
      escreva("\n\nAs nove caudas sentem que há um caminho possível: a reunificação completa. Mas o processo exige uma âncora — algo vivo que mantenha as facetas unidas durante a fusão.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\n'Ancore-nos.' — diz a Sabedoria — 'Seu corpo será o ponto de convergência. Não será agradável.'")
      u.aguarde(500)
      escreva("\n\nVocê não hesita.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\nAs nove caudas se lançam sobre você. Luz, dor, calor, frio — tudo ao mesmo tempo, como se o mundo inteiro passasse pelo seu peito de uma só vez.")
      u.aguarde(500)
      escreva("\n\nVocê grita. As veias do seu corpo brilham em prata. A terra treme.")
      u.aguarde(500)
      escreva("\n\nE então — silêncio.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\nQuando você abre os olhos, a primeira coisa que vê é ela.")
      u.aguarde(500)
      escreva("\n\nA jovem de cabelos prateados, inteira, de pé diante de você. Os olhos dela carregam milênios, mas a expressão é nova: alívio.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\n'Tamamo...' — você sussurra, com a voz rouca.")
      u.aguarde(400)
      escreva("\n\n'Ela sorri — e pela primeira vez, o sorriso é dela, não de nenhuma cauda.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\n'Eu voltei, Akira. Por causa de você.'")
      u.aguarde(400)
      escreva("\n\nTamamo reassume seu posto como Guardiã de Kai. A floresta volta a florescer. Os espíritos encontram ordem. O Monte Fuji deixa de sangrar.")
      u.aguarde(400)
      escreva("\n\nMas você não volta para a vila.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\nComo o mortal que ancorou a reunificação, seu corpo carrega marcas que não desaparecem...") 
      u.aguarde(300)
      escreva("\n\nVeias prateadas sob a pele, uma sensibilidade sobrenatural que torna o mundo comum insuportável.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\nAlém disso, algo mudou dentro de você. A fusão não apenas conectou as caudas — conectou você ao conhecimento acumulado de milênios.")
      u.aguarde(400)
      escreva("\n\nVocê sente a dor de cada árvore cortada. Ouviu o lamento de cada espírito esquecido. Entende a teia invisível que liga humanos, natureza e o divino.")
      u.aguarde(800)
      passarTexto()


      escreva("\n\nTamamo percebe antes de você mesmo.")
      u.aguarde(400)
      escreva("\n\n'Você não é mais apenas um mortal, Akira. A âncora não apenas sustentou — aprendeu.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nEla se ajoelha diante de você — a Guardiã de Kai, ajoelhada diante de um humano.")
      u.aguarde(300)
      escreva("\n\n'Eu sou a espada que protege Kai. Mas toda espada precisa de quem saiba quando empunhá-la e quando embainhá-la.'")
      u.aguarde(300)
      escreva("\n\n'Seja meu Sábio. Meu conselheiro eterno. A voz mortal que me lembra do que eu não posso mais ser.'")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nVocê aceita.")
      u.aguarde(300)
      escreva("\n\nOs anos se tornam décadas. As décadas se tornam séculos.")
      u.aguarde(300)
      escreva("\n\nVocê não envelhece — a âncora o prende ao mundo espiritual tanto quanto a Tamamo.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nMas diferente dela, você permanece mortal por dentro. Sente fome. Sente frio. Sente saudade das coisas simples que não pode mais ter.")
      u.aguarde(300)
      escreva("\n\nE é exatamente isso que faz de você o Sábio que Kai precisa.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nQuando Tamamo chora sozinha à noite, sentindo o peso da eternidade, você senta ao lado dela e diz:")
      u.aguarde(300)
      escreva("\n'Eu também nunca vou morrer. Pelo menos a eternidade não é solitária.'")
      u.aguarde(900)
      escreva("\n\nOs moradores de Kai contam histórias sobre a Guardiã de Prata e o Sábio que nunca envelhece.")
      u.aguarde(300)
      escreva("\nDizem que ele é mais poderoso que qualquer espírito, porque seu poder não é mágica — é compreensão.")
      u.aguarde(900)
      escreva("\nDizem que ela é a mais sácia das deusas, porque escolheu ouvir um mortal em vez de se impor.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nNas noites de festival, duas lanternas sobem pelo caminho da floresta.")
      u.aguarde(900)
      escreva("\nUma prateada, divina, eterna.")
      u.aguarde(900)
      escreva("\nOutra dourada, mortal, igualmente eterna.")
      u.aguarde(900)
      continuar()
      limpa()

      escreva("\n\nE quem vê de longe nunca sabe qual delas brilha mais forte.\n\n")
      u.aguarde(500)
      sabio()
      escreva("\n\n>> A Guardiã e o Sábio <<\n")
      continuar()
      limpa()

    } senao {

      escreva("\n<==========================================>\n")
      escreva("   ======== O NOVO EQUILÍBRIO DE KAI ========")
      escreva("\n<==========================================>\n")
      u.aguarde(600)

      escreva("\n\nA explosão foi devastadora. Kai leva cicatrizes que não vão sarar tão cedo.")
      u.aguarde(200)
      escreva("\nE as nove caudas, livres da corrupção, flutuam dispersas — cada uma recuperando sua identidade depois de séculos confinadas numa alma só.")
      u.aguarde(800)
      passarTexto()
      

      escreva("\n\nA Sabedoria é a primeira a falar:")
      u.aguarde(300)
      escreva("\n'Não podemos nos fundir. Não depois do que o Caos fez com nossos laços. Forçar a união agora seria repetir o mesmo erro que nos partiu por dentro.'")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nA Ira concorda com um grunhido. A Melancolia diz nada, mas seus olhos confirmam.")
      u.aguarde(200)
      escreva("\n\nTodas olham para você. Esperando. Sem Tamamo para comandá-las, você é a única referência que têm.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nEntão você faz a única coisa que faz sentido:")
      u.aguarde(200)
      escreva("\n'Então não se fundam. Cada uma de vocês decide o que quer ser.'")
      u.aguarde(200)
      escreva("\n\nO silêncio que segue é pesado. Nenhuma cauda jamais teve escolha.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nA Devoção e a Serenidade escolhem se reunir — não como Tamamo, mas como algo menor.")  
      u.aguarde(200)
      escreva("\nUma jovem de cabelos prateados emerge, com poder, sim, mas limitado. Quase humana. Mortal, em muitos sentidos.")
      u.aguarde(200)
      escreva("\n\nEla não é mais Tamamo-no-Mae, a Nove Caudas. Não é mais deusa. Não é mais guardiã absoluta.")
      u.aguarde(200)
      escreva("\nÉ uma mulher que lembra de ter sido divina, mas que agora sente frio, fome e solidão como qualquer outra.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nA Ira e a Astúcia partem para as montanhas, onde se tornam espíritos livres que protegem as fronteiras de Kai à sua própria maneira — implacáveis, indomáveis, mas leais.")
      u.aguarde(200)
      escreva("\n\nA Melancolia desaparece nas névoas do vale. A Esperança se espalha pelas raízes das cerejeiras.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nTamamo não retorna como deusa. A estrutura antiga que sustentava Kai está quebrada.")
      u.aguarde(200)
      escreva("\nE agora, o feudo precisa aprender algo que nenhuma geração precisou aprender:")
      u.aguarde(200)
      escreva("\nViver sem uma guardiã absoluta.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nNo começo, é caos.")
      u.aguarde(200)
      escreva("\nOs espíritos mais jovens se perdem sem alguém para lhes dar ordens.") 
      u.aguarde(200)
      escreva("\nOs humanos cortam árvores sem pedir permissão, porque já não há quem puna. As colheitas falham porque ninguém ora corretamente.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nA jovem quase humana que carrega o que restou de Tamamo olha para tudo isso com olhos que já foram divinos e agora apenas tristeçam.")
      escreva("\n'Eles vão se destruir,' — ela diz — 'sem alguém para guiá-los.'")
      u.aguarde(500)
      escreva("\n\n'Não sem alguém,' — você responde — 'Mas juntos. Se não há deusa, então humanos e espíritos precisam aprender a falar entre si. De verdade.'")
      u.aguarde(800)
      
      
      
      escreva("\n\nÉ o trabalho mais difícil que já existiu.")
      u.aguarde(200)
      escreva("\nNão há batalhas épicas. São conversas difíceis, acordos quebrados e reconstruídos, medos desmontados um por um.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nVocê ensina os humanos que espíritos não são servos — são vizinhos.")
      u.aguarde(200)
      escreva("\nA jovem que foi Tamamo ensina os espíritos que humanos não são frágeis — são diferentes.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nHá recaídas. Há conflitos. Há noites em que você questiona se não teria sido melhor forçar a fusão.")
      u.aguarde(200)
      escreva("\n\nMas então vê um fazendeiro deixando oferta de arroz na base de uma árvore antiga — não por medo, mas por respeito.")
      u.aguarde(200)
      escreva("\nE vê um kitsune jovem brincando com crianças na beira do rio — não como ilusão, mas como companheiro.")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\n'E se um dia os espíritos quiserem uma deusa de novo?' — a jovem pergunta, olhando o Monte Fuji ao pôr do sol.")
      u.aguarde(200)
      escreva("\n\n'Então eles escolherão. Como vocês escolheram. Como eu escolhi.'")
      u.aguarde(800)
      passarTexto()
      
      
      escreva("\n\nEla olha para você. Você olha para Kai.")
      u.aguarde(200)
      escreva("\nPela primeira vez em mil anos, o feudo não pertence a nenhuma guardiã.")
      u.aguarde(200)
      escreva("\nPertence a todos.")
      u.aguarde(1000)
      passarTexto()
      

      escreva("\nE isso, no final, é mais forte do que qualquer divindade.\n\n")
      u.aguarde(300)
      heroi()
      escreva("\n>> O Novo Equilíbrio de Kai <<\n")
      continuar()
      limpa()

    }
    limpa()
    u.aguarde(800)
    escreva("\nObrigado por jogar A Nove Caudas de Kai.")
    u.aguarde(300)
    escreva("\nO Feudo de Kai lembrará seu nome, Akira.\n")
    u.aguarde(300)
    escreva("\nEQUIPE CDS\n\n\n")
    u.aguarde(500)
    game_over()
  }

    // --- FUNÇÃO REUTILIZÁVEL: VALIDAÇÃO DE ENTRADA ---
    // Esta função impede que o código quebre se o usuário digitar letras ou números errados
    funcao inteiro obter_opcao(inteiro min, inteiro max) 
  {
        cadeia entrada
        inteiro n = 0
        logico ok = falso

        faca {
            escreva("\n\nDigite sua escolha: ")
            leia(entrada) // Lê como texto para não travar o programa

            // 1. Verifica se o texto é um número
            se (tp.cadeia_e_inteiro(entrada, 10)) {
                n = tp.cadeia_para_inteiro(entrada, 10)
                
                // 2. Verifica se o número está entre as opções válidas
                se (n >= min e n <= max) {
                    ok = verdadeiro
                } senao {
                    escreva("Opção inválida! Escolha entre ", min, " e ", max, ".")
                }
            } senao {
                escreva("Erro: Digite apenas um número (", min, " a ", max, ").")
            }
        } enquanto (nao ok)

        retorne n // Devolve o número limpo e validado para quem chamou a função
    }

  funcao continuar(){
   escreva("\n\n<============================================> ")
   u.aguarde(300)
   escreva("\n<====== Pressione ENTER para continuar ======> ")
   u.aguarde(300)
   escreva("\n<============================================> ")
   leia(enter)
  }

  funcao passarTexto() {
   escreva("\n\n")
   escreva("\n--------------------------------------------------") 
   escreva("\n    [ Pressione ENTER para continuar lendo ]") 
   escreva("\n--------------------------------------------------") 
   leia(enter)
   escreva("\n") 
  }

